    {
      "parameters": {
        "jsCode": "return Array.from({ length: 20 }).map((_, i) => {\n  const expected = new Date(\"2026-03-01\");\n  const today = new Date(\"2026-03-20\");\n\n  const delay_days = Math.ceil((today - expected) / (1000 * 60 * 60 * 24));\n\n  let exception = \"none\";\n  let reason = \"on time\";\n\n  if (delay_days > 0) {\n    exception = \"delay\";\n\n    // 👇 phân loại lý do\n    if (delay_days >= 10) {\n      reason = \"Weather issue\";\n    } else if (delay_days >= 5) {\n      reason = \"Transportation delay\";\n    } else {\n      reason = \"Minor delay\";\n    }\n  }\n\n  return {\n    json: {\n      shipment_id: \"S\" + (1000 + i),\n      status: \"In Transit\",\n      expected_date: \"2026-03-01\",\n      current_date: \"2026-03-20\",\n      delay_days: delay_days,\n      exception: exception,\n      reason: reason\n    }\n  };\n});"
      },
