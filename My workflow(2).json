    {
      "parameters": {
        "jsCode": "const items = $json.data;\n\n// tổng shipment\nconst total = items.length;\n\n// đếm delay\nlet delayed = 0;\n\n// đếm theo lý do\nconst reasonCount = {};\n\nitems.forEach(item => {\n  if (item.exception === \"delay\") {\n    delayed++;\n\n    if (!reasonCount[item.reason]) {\n      reasonCount[item.reason] = 0;\n    }\n\n    reasonCount[item.reason]++;\n  }\n});\n\nreturn [\n  {\n    json: {\n      total_shipments: total,\n      delayed_shipments: delayed,\n      reasons: reasonCount\n    }\n  }\n];"
      },
