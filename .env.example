## Ports (host → containers)
NGINX_HOST_PORT=80
N8N_HOST_PORT=5679

## Postgres
POSTGRES_DB=shipment
POSTGRES_USER=shipment
POSTGRES_PASSWORD=shipment

## Backend (FastAPI)
APP_ENV=dev
APP_DB_URL=postgresql+psycopg://shipment:shipment@postgres:5432/shipment
WEBAPI_DB_DSN=postgresql://shipment:shipment@postgres:5432/shipment
APP_REDIS_URL=redis://redis:6379/0
APP_JWT_SECRET=dev-secret-change-me
APP_JWT_ALG=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=480
APP_SEED_ON_STARTUP=1
DETECTOR_DEDUP_TTL_SECONDS=3600

## AI Classifier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=12

## Notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPS_CHAT_ID=
TELEGRAM_MANAGER_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_OPS_RECIPIENT=
EMAIL_MANAGER_RECIPIENT=

## Frontend (Next.js)
NEXT_PUBLIC_API_BASE=/api
API_INTERNAL_BASE=http://api:8000/api
VITE_USE_MOCK_DATA=false

## n8n
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh
N8N_HOST=localhost
N8N_PATH=/
N8N_WEBHOOK_URL=http://localhost/
N8N_EDITOR_BASE_URL=http://localhost/
N8N_PROXY_HOPS=1

# Basic auth for n8n UI
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
